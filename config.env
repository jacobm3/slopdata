#!/usr/bin/env bash
# ============================================================================
# config.env  --  ALL user-tunable settings for the synthetic data demo.
#
# Edit the values below, then run ./bootstrap.sh
# Everything has a sensible, low-cost default. You can usually just set PREFIX
# and PROJECT_ID and leave the rest alone.
# ============================================================================

# ---- Required-ish -----------------------------------------------------------

# A short prefix put in front of EVERY resource name so you can find (and
# delete) them easily, and tell them apart from your other GCP resources.
# Use lower-case letters, digits and hyphens only (e.g. "sdp-demo", "acme").
PREFIX="sdp-demo"

# GCP project to deploy into. Leave blank to use whatever project your
# Cloud Shell / gcloud is currently set to (gcloud config get-value project).
PROJECT_ID=""

# Region for all resources. us-central1 is the cheapest broad-support region.
REGION="us-central1"

# ---- Which data types to generate (true/false) ------------------------------
ENABLE_CUSTOMERS=true     # PII + credit-card data, incl. PCI-violating fields
ENABLE_MEDICAL=true       # Synthea synthetic patient records (FHIR/CSV)
ENABLE_PATENTS=true       # Intellectual property / patent filings
ENABLE_FINANCIAL=true     # Annual financial / accounting records
ENABLE_SECRETS=true       # Leaked credentials: API keys, SA keys, JWTs, etc.

# ---- How much data per type -------------------------------------------------
# Accepts: 10KB 100KB 1MB 10MB 100MB 1GB 10GB ... (KB/MB/GB = 1000-based)
# Bigger = more SDP findings, but more generation time, storage and (for the
# database) import cost. 10MB is plenty for a discovery demo.
VOL_CUSTOMERS="10MB"
VOL_MEDICAL="10MB"
VOL_PATENTS="10MB"
VOL_FINANCIAL="10MB"
VOL_SECRETS="10KB"        # secrets are tiny/high-signal; you don't need much

# ---- Managed database (the only meaningful recurring cost) ------------------
# Provisions a Cloud SQL (PostgreSQL) instance and imports the customer data
# so SDP can discover sensitive data inside a real database too.
# db-f1-micro (shared core, 10GB HDD) is the smallest tier (~$8-10/mo if left
# running). Set to false for the cheapest possible demo (buckets + BigQuery
# only, near-zero idle cost).
ENABLE_CLOUDSQL=true

# ---- Cost guardrails --------------------------------------------------------
# Objects in the bucket auto-delete after this many days so a forgotten demo
# can't accumulate storage cost. Set to 0 to disable auto-deletion.
RETENTION_DAYS=7
